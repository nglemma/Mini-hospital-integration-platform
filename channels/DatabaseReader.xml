            <script>// Read values from the HL7 ACK returned by Hospital B
// =============================================================
// DATABASE READER — ACK RESPONSE HANDLER
//
// Responsibility:
//   AA -&gt; mark the encounter COMPLETED
//   AE -&gt; mark the encounter RETRY_PENDING
//   AR -&gt; mark the encounter DEAD_LETTER
//
// This script does NOT perform retries.
// The separate Retry_Manager channel will perform retries.
// =============================================================


// -------------------------------------------------------------
// 1. Helper function: safely convert Mirth/Java values to strings
// -------------------------------------------------------------

function cleanValue(value) {
    if (value == null) {
        return &apos;&apos;;
    }

    return String(value)
        .replace(/\u0000/g, &apos;&apos;)
        .trim();
}


// -------------------------------------------------------------
// 2. Read the ACK returned by Hospital B
// -------------------------------------------------------------

var acknowledgementCode = cleanValue(
    msg[&apos;MSA&apos;][&apos;MSA.1&apos;][&apos;MSA.1.1&apos;]
);

var originalControlId = cleanValue(
    msg[&apos;MSA&apos;][&apos;MSA.2&apos;][&apos;MSA.2.1&apos;]
);

var acknowledgementText = cleanValue(
    msg[&apos;MSA&apos;][&apos;MSA.3&apos;][&apos;MSA.3.1&apos;]
);


// MSA-3 may legitimately be blank in an AA response.
if (acknowledgementText === &apos;&apos;) {
    acknowledgementText = &apos;No acknowledgement text supplied&apos;;
}


// -------------------------------------------------------------
// 3. Retrieve the encounter identity from the sender channel
// -------------------------------------------------------------

var visitIdText = cleanValue($(&apos;visit_id&apos;));

if (visitIdText === &apos;&apos; || !/^\d+$/.test(visitIdText)) {
    throw &apos;ACK handler cannot continue because visit_id is missing &apos; +
          &apos;or invalid. Received: [&apos; + visitIdText + &apos;]&apos;;
}

var visitId = Number(visitIdText);


// -------------------------------------------------------------
// 4. Store ACK details for message inspection and logging
// -------------------------------------------------------------

channelMap.put(&apos;ack_code&apos;, acknowledgementCode);
channelMap.put(&apos;ack_control_id&apos;, originalControlId);
channelMap.put(&apos;ack_text&apos;, acknowledgementText);
channelMap.put(&apos;ack_visit_id&apos;, visitIdText);

logger.info(
    &apos;ACK received from Hospital B. &apos; +
    &apos;Code=&apos; + acknowledgementCode +
    &apos;, Control ID=&apos; + originalControlId +
    &apos;, Visit=&apos; + visitId +
    &apos;, Text=&apos; + acknowledgementText
);


// -------------------------------------------------------------
// 5. Update the sender database according to the ACK
// -------------------------------------------------------------

var dbConn = null;

try {
    dbConn = DatabaseConnectionFactory.createDatabaseConnection(
        &apos;com.mysql.cj.jdbc.Driver&apos;,
        &apos;jdbc:mysql://localhost:3306/demoehr&apos;,
        &apos;root&apos;,
        &apos;------------&apos;
    );


    // =========================================================
    // AA — Application Accept
    // Hospital B accepted and processed the message.
    // =========================================================

    if (acknowledgementCode === &apos;AA&apos;) {

        var aaSql =
            &apos;UPDATE Encounters &apos; +
            &apos;SET processed = 1, &apos; +
                &apos;processing_status = ?, &apos; +
                &apos;retry_count = 0, &apos; +
                &apos;dlq_flag = 0, &apos; +
                &apos;last_error = NULL, &apos; +
                &apos;next_retry_at = NULL, &apos; +
                &apos;last_attempt_at = NOW() &apos; +
            &apos;WHERE visitid = ?&apos;;

        var aaRows = dbConn.executeUpdate(aaSql, [
            &apos;COMPLETED&apos;,
            visitId
        ]);

        if (Number(aaRows) !== 1) {
            throw &apos;AA handling expected to update one encounter, but updated &apos; +
                  aaRows + &apos;. Visit=&apos; + visitId;
        }

        channelMap.put(&apos;delivery_status&apos;, &apos;COMPLETED&apos;);

        logger.info(
            &apos;AA processed successfully. Visit=&apos; +
            visitId +
            &apos; marked COMPLETED.&apos;
        );


    // =========================================================
    // AE — Application Error
    // Hospital B received the message but could not process it.
    //
    // Do not increment retry_count here.
    // Do not resend here.
    //
    // The Retry_Manager will select RETRY_PENDING records when
    // next_retry_at becomes due.
    // =========================================================

    } else if (acknowledgementCode === &apos;AE&apos;) {

        var aeSql =
            &apos;UPDATE Encounters &apos; +
            &apos;SET processed = 0, &apos; +
                &apos;processing_status = ?, &apos; +
                &apos;last_error = ?, &apos; +
                &apos;next_retry_at = DATE_ADD(NOW(), INTERVAL 30 SECOND), &apos; +
                &apos;last_attempt_at = NOW() &apos; +
            &apos;WHERE visitid = ?&apos;;

        var aeRows = dbConn.executeUpdate(aeSql, [
            &apos;RETRY_PENDING&apos;,
            acknowledgementText,
            visitId
        ]);

        if (Number(aeRows) !== 1) {
            throw &apos;AE handling expected to update one encounter, but updated &apos; +
                  aeRows + &apos;. Visit=&apos; + visitId;
        }

        channelMap.put(&apos;delivery_status&apos;, &apos;RETRY_PENDING&apos;);

        logger.warn(
            &apos;AE processed successfully. Visit=&apos; +
            visitId +
            &apos; marked RETRY_PENDING. &apos; +
            &apos;Retry_Manager may retry it after 30 seconds.&apos;
        );


    // =========================================================
    // AR — Application Reject
    // Hospital B rejected the message completely.
    //
    // AR is not retryable in this design.
    // Mark it for later DLQ processing.
    // =========================================================

    } else if (acknowledgementCode === &apos;AR&apos;) {

        var arSql =
            &apos;UPDATE Encounters &apos; +
            &apos;SET processed = 0, &apos; +
                &apos;processing_status = ?, &apos; +
                &apos;dlq_flag = 1, &apos; +
                &apos;last_error = ?, &apos; +
                &apos;next_retry_at = NULL, &apos; +
                &apos;last_attempt_at = NOW() &apos; +
            &apos;WHERE visitid = ?&apos;;

        var arRows = dbConn.executeUpdate(arSql, [
            &apos;DEAD_LETTER&apos;,
            acknowledgementText,
            visitId
        ]);

        if (Number(arRows) !== 1) {
            throw &apos;AR handling expected to update one encounter, but updated &apos; +
                  arRows + &apos;. Visit=&apos; + visitId;
        }

        channelMap.put(&apos;delivery_status&apos;, &apos;DEAD_LETTER&apos;);

        logger.error(
            &apos;AR processed successfully. Visit=&apos; +
            visitId +
            &apos; marked DEAD_LETTER.&apos;
        );


    // =========================================================
    // Unknown ACK
    // =========================================================

    } else {
        throw &apos;Unexpected ACK code received from Hospital B: [&apos; +
              acknowledgementCode + &apos;]&apos;;
    }


} catch (ackHandlerError) {

    logger.error(
        &apos;ACK state update failed. &apos; +
        &apos;Visit=&apos; + visitId +
        &apos;, ACK=&apos; + acknowledgementCode +
        &apos;, Error=&apos; + String(ackHandlerError)
    );

    throw ackHandlerError;


} finally {

    if (dbConn != null) {
        dbConn.close();
    }
}</script>
