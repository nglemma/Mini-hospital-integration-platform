      <select>SELECT
    pd.patientid AS patient_id,
    pd.dob AS dob,
    pd.gender AS gender,
    pd.address AS address,
    pd.city AS city,
    pd.state AS state,
    pd.postcode AS postcode,
    pd.phone AS phone,

    pn.firstname AS first_name,
    pn.lastname AS last_name,
    pn.middlename AS middle_name,

    e.visitid AS visit_id,
    e.encountertype AS encounter_type,
    e.location AS location,
    e.admitdate AS admit_date,
    e.provider AS provider,

    nk.relationship AS kin_relationship,
    nk.firstname AS kin_first_name,
    nk.lastname AS kin_last_name,
    nk.phone AS kin_phone,
    nk.address AS kin_address,

    al.allergy_code AS allergy_code,
    al.allergy_description AS allergy_description,
    al.reaction AS allergy_reaction,
    al.severity AS allergy_severity,

    dg.diagnosis_code AS diagnosis_code,
    dg.diagnosis_description AS diagnosis_description,
    dg.diagnosis_type AS diagnosis_type

FROM PatientDemographics pd
JOIN PatientNames pn
    ON pd.patientid = pn.patientid
JOIN Encounters e
    ON pd.patientid = e.patientid
LEFT JOIN NextOfKin nk
    ON pd.patientid = nk.patientid
LEFT JOIN Allergies al
    ON pd.patientid = al.patientid
LEFT JOIN Diagnoses dg
    ON e.visitid = dg.visitid
WHERE e.processed = 0
  AND e.dlq_flag = 0
  AND e.processing_status = &apos;NEW&apos;</select>
      <update>UPDATE Encounters
SET
    processing_status = &apos;SENT&apos;,
    last_attempt_at = NOW()
WHERE visitid = ${visit_id}
  AND processing_status = &apos;NEW&apos;;</update>
